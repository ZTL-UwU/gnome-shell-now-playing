{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "prefer-rest-params": "warn"
  },
  "ignorePatterns": ["dist/**", "node_modules/**"],
  "env": {
    "builtin": true
  }
}
